RewriteEngine On

# ─── Dynamic Sitemap ──────────────────────────────────────────────────────
# This must be high to override physical file checks
RewriteRule ^sitemap\.xml$ generate-sitemap.php [L]

# ─── Force HTTPS + Strip www ───────────────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ─── Serve real files directly (fixes favicon) ───
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ─── Error Pages ───────────────────────────────────────────────────────────
ErrorDocument 404 /404.php
ErrorDocument 403 /404.php

 
# ─── Pretty URL Rules ──────────────────────────────────────────────────────
RewriteRule ^blog-detail/([a-zA-Z0-9-/]+)$ single-post.php?url=$1 [L]
RewriteRule ^brands/([^/\.]+)/?$ brands.php?url=$1 [L]
RewriteRule ^services/([^/\.]+)/?$ services.php?url=$1 [L]

# ─── Auto-append .php extension ────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteCond %{REQUEST_URI} !/$
RewriteRule (.*) $1\.php [L]

# BEGIN cPanel-generated php ini directives, do not edit
<IfModule php8_module>
   php_flag display_errors Off
   php_value max_execution_time 60
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 512M
   php_value post_max_size 516M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/tmp"
   php_value upload_max_filesize 512M
   php_flag zlib.output_compression Off
</IfModule>
<IfModule lsapi_module>
   php_flag display_errors Off
   php_value max_execution_time 60
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 512M
   php_value post_max_size 516M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/tmp"
   php_value upload_max_filesize 512M
   php_flag zlib.output_compression Off
</IfModule>
# END cPanel-generated php ini directives, do not edit